{%- comment -%}
  Snippet: hero-elite-block
  Params: block, delay_s
{%- endcomment -%}

{%- case block.type -%}

  {%- when 'eyebrow' -%}
    <p
      class="hero-elite__eyebrow hero-elite__anim"
      style="animation-delay: {{ delay_s }}{% if block.settings.text_color != blank %}; color: {{ block.settings.text_color }}{% endif %}"
      {{ block.shopify_attributes }}
    >
      {{- block.settings.text -}}
    </p>

  {%- when 'heading' -%}
    <{{ block.settings.heading_tag }}
      class="hero-elite__heading hero-elite__anim {{ block.settings.heading_size }} inline-richtext"
      style="animation-delay: {{ delay_s }}{% if block.settings.text_color != blank %}; color: {{ block.settings.text_color }}{% endif %}"
      {{ block.shopify_attributes }}
    >
      {{ block.settings.heading }}
    </{{ block.settings.heading_tag }}>

  {%- when 'subheading' -%}
    <p
      class="hero-elite__subheading hero-elite__anim subtitle"
      style="animation-delay: {{ delay_s }}{% if block.settings.text_color != blank %}; color: {{ block.settings.text_color }}{% endif %}"
      {{ block.shopify_attributes }}
    >
      {{- block.settings.text -}}
    </p>

  {%- when 'text' -%}
    <div
      class="hero-elite__text hero-elite__anim rte {{ block.settings.text_style }}"
      style="animation-delay: {{ delay_s }}{% if block.settings.text_color != blank %}; color: {{ block.settings.text_color }}{% endif %}"
      {{ block.shopify_attributes }}
    >
      {{ block.settings.text }}
    </div>

  {%- when 'inline_rating' -%}
    <div
      class="hero-elite__inline-rating hero-elite__anim"
      style="animation-delay: {{ delay_s }}{% if block.settings.text_color != blank %}; color: {{ block.settings.text_color }}{% endif %}"
      {{ block.shopify_attributes }}
    >
      <span
        class="hero-elite__stars"
        style="color: {{ block.settings.star_color | default: '#22a06b' }}"
        aria-label="{{ block.settings.rating_value }} out of 5 stars"
      >★★★★★</span>
      <span class="hero-elite__rating-inline-text">
        <strong style="color: {{ block.settings.rating_value_color | default: 'inherit' }}">{{ block.settings.rating_value }}</strong>
        {%- if block.settings.rating_label != blank %} {{ block.settings.rating_label }}{%- endif -%}
        {%- if block.settings.segment_1_number != blank or block.settings.segment_1_label != blank -%}
          <span class="hero-elite__rating-sep" aria-hidden="true"> | </span>
          {%- if block.settings.segment_1_number != blank -%}<strong style="color: {{ block.settings.segment_1_color | default: 'inherit' }}">{{ block.settings.segment_1_number }}</strong>{%- endif -%}
          {%- if block.settings.segment_1_label != blank %} {{ block.settings.segment_1_label }}{%- endif -%}
        {%- endif -%}
        {%- if block.settings.segment_2_number != blank or block.settings.segment_2_label != blank -%}
          <span class="hero-elite__rating-sep" aria-hidden="true"> | </span>
          {%- if block.settings.segment_2_number != blank -%}<strong style="color: {{ block.settings.segment_2_color | default: 'inherit' }}">{{ block.settings.segment_2_number }}</strong>{%- endif -%}
          {%- if block.settings.segment_2_label != blank %} {{ block.settings.segment_2_label }}{%- endif -%}
        {%- endif -%}
      </span>
    </div>

  {%- when 'trust_badge' -%}
    <div
      class="hero-elite__trust-badge hero-elite__anim"
      style="animation-delay: {{ delay_s }}{% if block.settings.text_color != blank %}; color: {{ block.settings.text_color }}{% endif %}"
      {{ block.shopify_attributes }}
    >
      <span
        class="hero-elite__trust-icon"
        style="{% if block.settings.icon_color != blank %}color: {{ block.settings.icon_color }};{% endif %}"
        aria-hidden="true"
      >
        {%- case block.settings.icon -%}
          {%- when 'check' -%}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2.5 8.5l3.5 3.5 7.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {%- when 'shield' -%}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 1.5L2.5 4v4.5c0 3 2.5 5.5 5.5 6 3-.5 5.5-3 5.5-6V4L8 1.5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
          {%- when 'lock' -%}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="7" width="10" height="8" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M5 7V5a3 3 0 016 0v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          {%- when 'truck' -%}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 3h9v8H1V3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M10 5.5h2.5L14 8v3h-4V5.5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><circle cx="4" cy="11.5" r="1.5" stroke="currentColor" stroke-width="1.2"/><circle cx="12" cy="11.5" r="1.5" stroke="currentColor" stroke-width="1.2"/></svg>
          {%- when 'leaf' -%}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3 13c1-5 5-9 10-10C12 9 8 13 3 13z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M3 13l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        {%- endcase -%}
      </span>
      <span class="hero-elite__trust-text">{{- block.settings.text | escape -}}</span>
      {%- if block.settings.tooltip != blank -%}
        <button
          class="hero-elite__trust-info"
          type="button"
          title="{{ block.settings.tooltip | escape }}"
          aria-label="{{ block.settings.tooltip | escape }}"
        >
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2"/>
            <path d="M7 6.3V10M7 4.5v.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </button>
      {%- endif -%}
    </div>

  {%- when 'rating_badge' -%}
    <div
      class="hero-elite__rating-wrap hero-elite__anim"
      style="animation-delay: {{ delay_s }}"
      {{ block.shopify_attributes }}
    >
      {%- render 'glass-rating-badge', block: block -%}
    </div>

  {%- when 'buttons' -%}
    {%- liquid
      assign btn1_style = block.settings.button_style_1
      assign btn2_style = block.settings.button_style_2
      assign btn1_bg    = block.settings.button_color_bg_1
      assign btn1_text  = block.settings.button_color_text_1
      assign btn2_bg    = block.settings.button_color_bg_2
      assign btn2_text  = block.settings.button_color_text_2
    -%}
    <div
      class="hero-elite__buttons hero-elite__anim{% if block.settings.button_label_1 != blank and block.settings.button_label_2 != blank %} hero-elite__buttons--double{% endif %}"
      style="animation-delay: {{ delay_s }}"
      {{ block.shopify_attributes }}
    >
      {%- if block.settings.button_label_1 != blank -%}
        <a
          {% if block.settings.button_link_1 == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ block.settings.button_link_1 }}"
          {% endif %}
          class="hero-btn hero-btn--{{ btn1_style }}"
          style="--hbtn-bg: {{ btn1_bg }}; --hbtn-text: {{ btn1_text }};"
        >
          <span>{{- block.settings.button_label_1 | escape -}}</span>
        </a>
      {%- endif -%}
      {%- if block.settings.button_label_2 != blank -%}
        <a
          {% if block.settings.button_link_2 == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ block.settings.button_link_2 }}"
          {% endif %}
          class="hero-btn hero-btn--{{ btn2_style }}"
          style="--hbtn-bg: {{ btn2_bg }}; --hbtn-text: {{ btn2_text }};"
        >
          <span>{{- block.settings.button_label_2 | escape -}}</span>
        </a>
      {%- endif -%}
    </div>

  {%- when 'divider' -%}
    <div
      class="hero-elite__divider hero-elite__anim"
      style="animation-delay: {{ delay_s }}"
      {{ block.shopify_attributes }}
    >
      <span class="hero-elite__divider-line"></span>
      {%- if block.settings.text != blank -%}
        <span class="hero-elite__divider-text">{{ block.settings.text }}</span>
        <span class="hero-elite__divider-line"></span>
      {%- endif -%}
    </div>

{%- endcase -%}
